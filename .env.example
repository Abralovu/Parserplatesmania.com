# Задержка между запросами (секунды)
DELAY_MIN=1.5
DELAY_MAX=4.0

# Прокси (опционально)
# PROXY_URL=http://user:pass@host:port

# Пути
OUTPUT_DIR=./data
DB_PATH=./data/plates.db

# Chrome профиль — найди свой в chrome://version/
# Mac:     ~/Library/Application Support/Google/Chrome/Default
# Windows: C:\Users\ИМЯ\AppData\Local\Google\Chrome\User Data\Default
CHROME_PROFILE=~/Library/Application Support/Google/Chrome/Profile 3

LOG_LEVEL=INFO
